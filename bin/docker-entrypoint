#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

if [ "${1:-}" = "/app/bin/start" ] || [ "${1:-}" = "bin/start" ]; then
  mkdir -p "$HOME/.pi/agent/sessions" "$HOME/.pi/web-gateway" /work

  if [ -z "${PI_GATEWAY_ADMIN_PASSWORD:-}" ]; then
    "$script_dir/gateway-password"
    unset PI_GATEWAY_ADMIN_PASSWORD
  fi
fi

exec "$@"
