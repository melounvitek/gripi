#!/usr/bin/env bash
set -euo pipefail

config_dir="${GRIPI_CONFIG_DIR:-$HOME/.config/gripi}"
env_file="${GRIPI_ENV_PATH:-$config_dir/env}"

mkdir -p "$(dirname "$env_file")"
touch "$env_file"
chmod 600 "$env_file"

if grep -q '^GRIPI_ADMIN_PASSWORD=' "$env_file"; then
  exit 0
fi

password="$(ruby -rsecurerandom -e 'puts SecureRandom.hex(12)')"
if [ -s "$env_file" ] && [ "$(tail -c 1 "$env_file")" != "" ]; then
  printf '\n' >> "$env_file"
fi
printf 'GRIPI_ADMIN_PASSWORD=%s\n' "$password" >> "$env_file"
echo "Generated GRIPI_ADMIN_PASSWORD in $env_file"
echo "Admin password: $password"
echo "You should change it by editing $env_file"
