#!/usr/bin/env bash
set -euo pipefail

host="${1:-${GRIPI_HOST:-127.0.0.1}}"
port="${GRIPI_PORT:-4567}"

if [[ -n "${GRIPI_RESTART_PATH:-}" ]]; then
  restart_path="$GRIPI_RESTART_PATH"
elif [[ -n "${HOME:-}" ]]; then
  restart_path="$HOME/.pi/gripi/restart-request"
else
  printf 'HOME or GRIPI_RESTART_PATH must be set\n' >&2
  exit 1
fi

rm -f -- "$restart_path"

puma_host="$host"
if [[ "$host" == *:* && "$host" != \[*\] ]]; then
  puma_host="[$host]"
fi

set +e
RACK_ENV=production GRIPI_BIND_HOST="$host" bundle exec puma -C config/puma.rb -b "tcp://$puma_host:$port"
status=$?
set -e

if [[ -e "$restart_path" ]]; then
  rm -- "$restart_path"
  exec "${BASH_SOURCE[0]}" "$@"
fi

exit "$status"
