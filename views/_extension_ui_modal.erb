  <div class="modal-overlay" data-modal="extension-ui-modal" hidden>
    <div class="modal-card extension-ui-modal-card" role="dialog" aria-modal="true" aria-labelledby="extension-ui-modal-title">
      <div class="modal-header">
        <h2 id="extension-ui-modal-title" data-extension-ui-title>Extension request</h2>
        <button type="button" class="modal-close-button secondary" aria-label="Cancel" tabindex="-1" data-extension-ui-cancel>&times;</button>
      </div>
      <form data-extension-ui-form>
        <p class="extension-ui-message" data-extension-ui-message hidden></p>
        <div class="extension-ui-options" data-extension-ui-options hidden></div>
        <label class="modal-field" data-extension-ui-input-field hidden>
          <span data-extension-ui-input-label>Value</span>
          <input type="text" data-extension-ui-input autocomplete="off">
        </label>
        <label class="modal-field" data-extension-ui-editor-field hidden>
          <span data-extension-ui-editor-label>Text</span>
          <textarea data-extension-ui-editor rows="8"></textarea>
        </label>
        <div class="modal-actions" data-extension-ui-actions>
          <button type="button" class="secondary" data-extension-ui-cancel>Cancel</button>
          <button type="submit" data-extension-ui-submit data-modal-default-focus>Submit</button>
        </div>
      </form>
    </div>
  </div>
