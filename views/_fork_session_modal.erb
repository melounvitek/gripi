  <div class="modal-overlay" data-modal="fork-session-modal" hidden>
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="fork-session-modal-title">
      <div class="modal-header">
        <h2 id="fork-session-modal-title">Fork session</h2>
        <button type="button" class="modal-close-button secondary" aria-label="Close" data-modal-close>&times;</button>
      </div>
      <% if @selected_session %>
        <div class="fork-session-list" data-fork-session-list data-fork-messages-url="/sessions/fork_messages?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
          <p class="fork-session-status" data-fork-session-status>Loading fork points…</p>
        </div>
      <% else %>
        <p class="fork-session-status">Select a session before forking.</p>
      <% end %>
      <div class="modal-actions">
        <button type="button" class="secondary" data-modal-close>Cancel</button>
      </div>
    </div>
  </div>

  <div class="modal-overlay" data-modal="tree-session-modal" hidden>
    <div class="modal-card tree-session-card" role="dialog" aria-modal="true" aria-labelledby="tree-session-modal-title">
      <div class="modal-header">
        <h2 id="tree-session-modal-title">Session tree</h2>
        <button type="button" class="modal-close-button secondary" aria-label="Close" data-modal-close>&times;</button>
      </div>
      <% if @selected_session %>
        <section class="tree-session-browser" data-tree-browser-step>
          <div class="tree-session-toolbar">
            <label class="modal-field">
              Search
              <input type="search" placeholder="Search tree…" autocomplete="off" data-tree-search data-modal-default-focus>
            </label>
            <label class="modal-field">
              Filter
              <select data-tree-filter>
                <option value="default">Default</option>
                <option value="no-tools">No tools</option>
                <option value="user-only">User only</option>
                <option value="labeled-only">Labeled only</option>
                <option value="all">All entries</option>
              </select>
            </label>
            <label class="tree-session-timestamp-toggle">
              <input type="checkbox" data-tree-label-timestamps>
              Label times
            </label>
          </div>
          <p class="tree-session-status" data-tree-session-status aria-live="polite">Loading session tree…</p>
          <div class="tree-session-list" data-tree-session-list data-tree-entries-url="/sessions/tree_entries?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
            <ul class="tree-session-tree" role="tree" aria-label="Session entries" data-tree-viewport></ul>
          </div>
          <form class="tree-session-label-form" action="/sessions/tree/label" method="post" data-tree-label-form>
            <label class="modal-field">
              Selected entry label
              <input type="text" maxlength="1024" placeholder="Optional label" data-tree-label-input>
            </label>
            <div class="tree-session-label-actions">
              <button type="button" class="secondary" data-tree-label-clear disabled>Clear</button>
              <button type="submit" class="secondary" data-tree-label-save disabled>Save label</button>
            </div>
          </form>
          <p class="tree-session-help" data-tree-help>
            <strong>Badges:</strong> Active is selected, Current is open, Latest is newest.<br>
            <strong>Keyboard:</strong> ↑/↓ select · ←/→ fold or move · Home/End/Page move · Enter navigate · Esc close · / or Ctrl+F search · Ctrl+O filter · Shift+L label
          </p>
          <div class="modal-actions">
            <button type="button" class="secondary" data-modal-close>Cancel</button>
            <button type="button" data-tree-navigate disabled>Navigate</button>
          </div>
        </section>
        <section class="tree-session-summary" data-tree-summary-step hidden>
          <p class="tree-session-summary-heading">Choose how to prepare the branch context.</p>
          <form data-tree-summary-form>
            <fieldset class="tree-session-summary-choices">
              <legend>Summary</legend>
              <label><input type="radio" name="summary_mode" value="none" checked> No summary</label>
              <label><input type="radio" name="summary_mode" value="default"> Summarize</label>
              <label><input type="radio" name="summary_mode" value="custom"> Summarize with custom instructions</label>
            </fieldset>
            <textarea rows="4" placeholder="What should the summary focus on?" aria-label="Custom summary instructions" data-tree-custom-instructions hidden></textarea>
            <div class="modal-actions">
              <button type="button" class="secondary" data-tree-summary-back>Back</button>
              <button type="submit" data-tree-summary-submit>Navigate</button>
            </div>
          </form>
        </section>
      <% else %>
        <p class="tree-session-status">Select a session before opening the tree.</p>
        <div class="modal-actions">
          <button type="button" class="secondary" data-modal-close>Close</button>
        </div>
      <% end %>
    </div>
  </div>
