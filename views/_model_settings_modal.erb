<div class="modal-overlay" data-modal="model-settings-modal" role="dialog" aria-modal="true" aria-labelledby="model-settings-title" hidden>
  <div class="modal-card model-settings-card">
    <div class="modal-header">
      <h2 id="model-settings-title">Model &amp; thinking</h2>
      <button type="button" class="secondary modal-close-button" data-modal-close aria-label="Close model and thinking settings">×</button>
    </div>
    <form class="model-settings-form" data-model-settings-form>
      <label class="modal-field">
        Search models
        <input type="search" data-model-search data-modal-default-focus autocomplete="off" placeholder="Provider, model, or display name">
      </label>
      <p class="model-settings-status" data-model-settings-status role="status" aria-live="polite">Loading models…</p>
      <div class="model-settings-list" data-model-list aria-label="Available models"></div>
      <fieldset class="model-thinking-options" data-thinking-options hidden>
        <legend>Thinking</legend>
        <div data-thinking-levels></div>
      </fieldset>
      <div class="modal-actions">
        <button type="button" class="secondary" data-modal-close>Cancel</button>
        <button type="submit" data-model-settings-apply>Apply</button>
      </div>
    </form>
  </div>
</div>
